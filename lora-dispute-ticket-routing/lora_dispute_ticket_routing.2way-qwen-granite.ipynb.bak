   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Most common misroutes (count | TRUE → PREDICTED):\n",
      "    8 | Top-Up & Funding  →  Payments & Transfers\n",
      "    5 | Payments & Transfers  →  Top-Up & Funding\n",
      "    5 | Card Operations  →  Fees, Rates & Product Info\n",
      "    3 | Top-Up & Funding  →  Fees, Rates & Product Info\n",
      "    3 | Fees, Rates & Product Info  →  Card Operations\n",
