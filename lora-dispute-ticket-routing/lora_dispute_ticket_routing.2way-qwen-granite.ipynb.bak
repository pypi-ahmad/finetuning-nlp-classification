   "cell_type": "markdown",
   "id": "e43b6fa5",
   "metadata": {},
   "source": [
    "## 6 · Evaluation — fine-tuned vs zero-shot\n",
    "\n",
    "`trainer.model` is now the 4-bit base **with the trained LoRA adapter active**.\n",
    "We score the *same* test set the *same* way, so any difference is the adapter."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "a6570984",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-06-09T20:55:16.517540Z",
     "iopub.status.busy": "2026-06-09T20:55:16.517375Z",
     "iopub.status.idle": "2026-06-09T21:05:31.208747Z",
     "shell.execute_reply": "2026-06-09T21:05:31.208172Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Scoring 1200 test tickets (fine-tuned)...\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "FINE-TUNED: {'accuracy': 0.9583, 'macro_f1': 0.9583, 'top3_accuracy': 0.9917, 'ece': 0.3602}\n"
     ]
    }
   ],
   "source": [
    "# Free the optimizer/scheduler state before eval — on 8 GB the resident Adam\n",
    "# state (held by `trainer`) otherwise leaves too little room for scoring and OOMs.\n",
    "import gc\n",
    "ft_model = trainer.model.eval()\n",
    "del trainer\n",
    "gc.collect(); torch.cuda.empty_cache()\n",
    "torch.cuda.reset_peak_memory_stats()\n",
    "\n",
    "ft_scorer = RouteScorer(ft_model, tok, CONFIG)\n",
    "print(f\"Scoring {len(test_texts)} test tickets (fine-tuned)...\")\n",
    "probs_ft = ft_scorer.score_texts(test_texts)\n",
    "\n",
    "metrics_ft = routing_metrics(probs_ft, test_labels)\n",
    "metrics_ft[\"ece\"] = expected_calibration_error(probs_ft, test_labels)\n",
    "print(\"FINE-TUNED:\", {k: round(v, 4) for k, v in metrics_ft.items()})"
   ]
  },
