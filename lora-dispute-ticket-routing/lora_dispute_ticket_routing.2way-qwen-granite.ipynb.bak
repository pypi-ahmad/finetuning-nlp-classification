   "source": [
    "cmp = pd.DataFrame([\n",
    "    {\"backbone\":\"Qwen2.5-1.5B\", \"stage\":\"zero-shot\",  **{k:metrics_base[k] for k in ['accuracy','macro_f1','top3_accuracy','ece']}},\n",
    "    {\"backbone\":\"Qwen2.5-1.5B\", \"stage\":\"fine-tuned\", **{k:metrics_ft[k]   for k in ['accuracy','macro_f1','top3_accuracy','ece']}},\n",
    "    {\"backbone\":\"Granite-4.1-3B\",\"stage\":\"zero-shot\",  **{k:g_zs[k] for k in ['accuracy','macro_f1','top3_accuracy','ece']}},\n",
    "    {\"backbone\":\"Granite-4.1-3B\",\"stage\":\"fine-tuned\", **{k:g_ft[k] for k in ['accuracy','macro_f1','top3_accuracy','ece']}},\n",
    "]).set_index([\"backbone\",\"stage\"])\n",
    "display(cmp.style.format(\"{:.3f}\"))\n",
    "\n",
    "fig, ax = plt.subplots(1, 2, figsize=(14,4.8))\n",
    "# fine-tuned head-to-head\n",
    "ft_tbl = pd.DataFrame({\"Qwen2.5-1.5B\":[metrics_ft['accuracy'],metrics_ft['macro_f1'],metrics_ft['top3_accuracy']],\n",
    "                       \"Granite-4.1-3B\":[g_ft['accuracy'],g_ft['macro_f1'],g_ft['top3_accuracy']]},\n",
    "                      index=[\"accuracy\",\"macro_f1\",\"top3\"])\n",
    "ft_tbl.plot.bar(ax=ax[0], rot=0, color=[\"#2a7ab9\",\"#b9532a\"]); ax[0].set_ylim(0,1)\n",
    "ax[0].set_title(\"Fine-tuned: Qwen-1.5B vs Granite-3B\"); ax[0].legend(loc=\"lower right\")\n",
    "for c in ax[0].containers: ax[0].bar_label(c, fmt=\"%.2f\", fontsize=8, padding=2)\n",
    "# zero-shot -> fine-tuned macro-F1 lift per backbone\n",
    "lift = pd.DataFrame({\"zero-shot\":[metrics_base['macro_f1'],g_zs['macro_f1']],\n",
    "                     \"fine-tuned\":[metrics_ft['macro_f1'],g_ft['macro_f1']]},\n",
    "                    index=[\"Qwen2.5-1.5B\",\"Granite-4.1-3B\"])\n",
    "lift.plot.bar(ax=ax[1], rot=0, color=[\"#bbbbbb\",\"#444444\"]); ax[1].set_ylim(0,1)\n",
    "ax[1].set_title(\"Macro-F1 lift from QLoRA\"); ax[1].legend(loc=\"lower right\")\n",
    "for c in ax[1].containers: ax[1].bar_label(c, fmt=\"%.2f\", fontsize=8, padding=2)\n",
    "plt.tight_layout(); plt.savefig(CONFIG.figures_dir/\"granite_vs_qwen.png\", dpi=120, bbox_inches=\"tight\"); plt.show()"
   ]
