# Core models (different by design)
LORA_MODEL_NAME=distilgpt2
QLORA_MODEL_NAME=facebook/opt-350m

# Dataset and sampling
DATASET_NAME=dair-ai/emotion
TRAIN_SAMPLES=1800
VALIDATION_SAMPLES=300
TEST_SAMPLES=300
BASELINE_EVAL_SAMPLES=40
TUNED_EVAL_SAMPLES=80

# Training controls
MAX_LENGTH=192
LORA_MAX_STEPS=30
QLORA_MAX_STEPS=12
SEED=42

# Optional Hugging Face token (for gated models if you switch model names)
HF_TOKEN=
